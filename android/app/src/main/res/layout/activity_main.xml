<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0e1319">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Deep Focus Now"
            android:textColor="#5ad1a0"
            android:textSize="24sp"
            android:textStyle="bold"
            android:paddingBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Podaj IP kompa (widoczne w logu apki na kompie) i ta sama siec WiFi."
            android:textColor="#8aa0b3"
            android:textSize="13sp"
            android:paddingBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="IP kompa"
            android:textColor="#cfe3f2" />

        <EditText
            android:id="@+id/host"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="192.168.55.224"
            android:inputType="text"
            android:textColor="#ffffff"
            android:textColorHint="#55697d" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Port"
            android:textColor="#cfe3f2"
            android:paddingTop="10dp" />

        <EditText
            android:id="@+id/port"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="8770"
            android:inputType="number"
            android:textColor="#ffffff"
            android:textColorHint="#55697d" />

        <Button
            android:id="@+id/save"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Zapisz i polacz"
            android:layout_marginTop="16dp" />

        <TextView
            android:id="@+id/status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="..."
            android:textColor="#ffffff"
            android:textSize="18sp"
            android:gravity="center"
            android:padding="20dp"
            android:layout_marginTop="16dp"
            android:background="#141b24" />

        <Button
            android:id="@+id/startBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Wlacz nasluchiwanie"
            android:layout_marginTop="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Aby telefon mogl zamykac apki, wlacz usluge Dostepnosci:"
            android:textColor="#8aa0b3"
            android:textSize="13sp"
            android:paddingTop="20dp" />

        <Button
            android:id="@+id/accBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Otworz ustawienia Dostepnosci" />

        <Button
            android:id="@+id/notifBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ustawienia powiadomien"
            android:layout_marginTop="8dp" />
    </LinearLayout>
</ScrollView>
